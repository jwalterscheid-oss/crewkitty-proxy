{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/admin", "destination": "https://ldwrbkatgwnhsgrqwnwa.supabase.co/functions/v1/app/admin" },
    { "source": "/employee", "destination": "https://ldwrbkatgwnhsgrqwnwa.supabase.co/functions/v1/app/employee" },
    { "source": "/platform", "destination": "https://ldwrbkatgwnhsgrqwnwa.supabase.co/functions/v1/app/platform" },
    { "source": "/success", "destination": "https://ldwrbkatgwnhsgrqwnwa.supabase.co/functions/v1/app/success" },
    { "source": "/api/(.*)", "destination": "https://ldwrbkatgwnhsgrqwnwa.supabase.co/functions/v1/app/api/$1" },
    { "source": "/functions/v1/app/(.*)", "destination": "https://ldwrbkatgwnhsgrqwnwa.supabase.co/functions/v1/app/$1" }
  ],
  "headers": [
    { "source": "/(admin|employee|platform|success)", "headers": [
